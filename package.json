{
  "name": "megadrop",
  "version": "1.0.0",
  "scripts": {
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "tsc -p tsconfig.client.json && sass src/public/styles.scss public/styles.css",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "sass": "^1.66.1"
  }
}
